  "fixed_sql": [
    {
      "name": "fields",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"fields\" (\"id\" TEXT NOT NULL, \"user_account_id\" TEXT NOT NULL CHECK (LENGTH(TRIM(user_account_id)) >= 28), \"name\" TEXT NOT NULL CHECK (LENGTH(TRIM(name)) >= 1 AND LENGTH(name) <= 64), \"creation_at\" TEXT NOT NULL, \"last_modification_at\" TEXT NOT NULL CHECK (JULIANDAY(last_modification_at) >= JULIANDAY(creation_at)), \"usage_count\" INTEGER NOT NULL DEFAULT 0 CHECK (usage_count >= 0 AND usage_count <= 4294967295), \"color\" INTEGER NOT NULL DEFAULT 4294967295 CHECK (color >= 0 AND color <= 4294967295), PRIMARY KEY(id), UNIQUE(user_account_id, name));"
        }
      ]
    },
    {
      "name": "field_lists",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"field_lists\" (\"id\" TEXT NOT NULL, \"field_id\" TEXT NOT NULL REFERENCES fields(id), \"name\" TEXT NOT NULL CHECK (LENGTH(TRIM(name)) >= 1 AND LENGTH(name) <= 64), \"creation_at\" TEXT NOT NULL, \"last_modification_at\" TEXT NOT NULL CHECK (JULIANDAY(last_modification_at) >= JULIANDAY(creation_at)), \"language_tag\" TEXT NULL, \"check_type\" INTEGER NOT NULL DEFAULT 0 CHECK (check_type >= 0 AND check_type <= 3), \"sort_by\" INTEGER NOT NULL DEFAULT 0 CHECK (sort_by >= 0 AND sort_by < 14), \"does_read_answer\" INTEGER NOT NULL DEFAULT 0 CHECK (does_read_answer IN (0, 1)), \"usage_count\" INTEGER NOT NULL DEFAULT 0 CHECK (usage_count >= 0 AND usage_count <= 65535), \"color\" INTEGER NOT NULL DEFAULT 4294967295 CHECK (color >= 0 AND color <= 4294967295), \"emulation_number_of_questions\" INTEGER NULL CHECK (emulation_number_of_questions >= 0 AND emulation_number_of_questions <= 255), \"emulation_days\" TEXT NULL, \"tests_reading_question_letter_duration\" INTEGER NULL CHECK (tests_reading_question_letter_duration >= 1), \"tests_finding_answer_duration\" INTEGER NULL CHECK (tests_finding_answer_duration >= 1), \"tests_typing_answer_letter_duration\" INTEGER NULL CHECK (tests_typing_answer_letter_duration >= 1), \"study_till_correct_reading_question_letter_duration\" INTEGER NULL CHECK (study_till_correct_reading_question_letter_duration >= 1), \"study_till_correct_finding_answer_duration\" INTEGER NULL CHECK (study_till_correct_finding_answer_duration >= 1), \"study_till_correct_typing_answer_letter_duration\" INTEGER NULL CHECK (study_till_correct_typing_answer_letter_duration >= 1), \"tests_time_of_answer_action\" INTEGER NOT NULL DEFAULT 1 CHECK (tests_time_of_answer_action >= 0 AND tests_time_of_answer_action < 2), \"does_obfuscate_question\" INTEGER NOT NULL DEFAULT 0 CHECK (does_obfuscate_question IN (0, 1)), PRIMARY KEY(id), UNIQUE(field_id, name));"
        }
      ]
    },
    {
      "name": "entrys",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"entrys\" (\"id\" TEXT NOT NULL, \"field_list_id\" TEXT NOT NULL REFERENCES field_lists(id), \"answer\" TEXT NOT NULL CHECK (LENGTH(TRIM(answer)) >= 1 AND LENGTH(answer) <= 2000), \"question\" TEXT NOT NULL CHECK (LENGTH(TRIM(question)) >= 1 AND LENGTH(question) <= 2000), \"creation_at\" TEXT NOT NULL, \"last_modification_at\" TEXT NOT NULL CHECK (JULIANDAY(last_modification_at) >= JULIANDAY(creation_at)), \"order\" INTEGER NOT NULL DEFAULT 0 CHECK (\"order\" <= 65535 AND \"order\" >= 0), \"did_asked_at_current_test_round\" INTEGER NOT NULL DEFAULT 1 CHECK (did_asked_at_current_test_round IN (0, 1)), \"emulated_created_at\" TEXT NULL, \"rank\" INTEGER NOT NULL DEFAULT 1 CHECK (rank <= 3 AND rank >= 0), \"asked_count\" INTEGER NOT NULL DEFAULT 0 CHECK (asked_count >= 0), \"wrongly_answered_count\" INTEGER NOT NULL DEFAULT 0 CHECK (wrongly_answered_count >= 0), \"last_asked_at\" TEXT NULL, PRIMARY KEY(id), UNIQUE(field_list_id, answer, question));"
        }
      ]
    },
    {
      "name": "field_notes",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"field_notes\" (\"id\" TEXT NOT NULL, \"field_id\" TEXT NOT NULL REFERENCES fields(id), \"tex_t\" TEXT NOT NULL CHECK (LENGTH(TRIM(tex_t)) >= 1 AND LENGTH(tex_t) <= 2000), \"creation_at\" TEXT NOT NULL, \"last_modification_at\" TEXT NOT NULL CHECK (JULIANDAY(last_modification_at) >= JULIANDAY(creation_at)), PRIMARY KEY(id));"
        }
      ]
    },
    {
      "name": "field_list_notes",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"field_list_notes\" (\"id\" TEXT NOT NULL, \"field_list_id\" TEXT NOT NULL REFERENCES field_lists(id), \"tex_t\" TEXT NOT NULL CHECK (LENGTH(TRIM(tex_t)) >= 1 AND LENGTH(tex_t) <= 2000), \"creation_at\" TEXT NOT NULL, \"last_modification_at\" TEXT NOT NULL CHECK (JULIANDAY(last_modification_at) >= JULIANDAY(creation_at)), PRIMARY KEY(id));"
        }
      ]
    },
    {
      "name": "sessions",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"sessions\" (\"id\" TEXT NOT NULL, \"field_list_id\" TEXT NOT NULL REFERENCES field_lists(id), \"current_question_counter\" INTEGER NOT NULL CHECK (current_question_counter >= 0 AND current_question_counter <= 4294967295), \"tries_number\" INTEGER NOT NULL CHECK (tries_number >= 0 AND tries_number <= 255), \"tries_counter\" INTEGER NOT NULL DEFAULT 0 CHECK ((tries_counter >= 0 AND tries_counter <= 255)AND tries_counter < tries_number), \"elapsed_time\" INTEGER NOT NULL CHECK (elapsed_time >= 1), \"is_completed\" INTEGER NOT NULL DEFAULT 0 CHECK (is_completed IN (0, 1)), \"last_checked_answer_result\" INTEGER NOT NULL DEFAULT 0 CHECK (last_checked_answer_result IN (0, 1)), \"should_check_an_answer\" INTEGER NOT NULL DEFAULT 1 CHECK (should_check_an_answer IN (0, 1)), \"current_hint_counter\" INTEGER NOT NULL DEFAULT 0 CHECK (current_hint_counter >= 0 AND current_hint_counter <= 255), \"creation_at\" TEXT NOT NULL, \"last_modification_at\" TEXT NOT NULL CHECK (JULIANDAY(last_modification_at) >= JULIANDAY(creation_at)), PRIMARY KEY(id));"
        }
      ]
    },
    {
      "name": "session_entrys",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"session_entrys\" (\"session_id\" TEXT NOT NULL REFERENCES sessions(id), \"entry_id\" TEXT NOT NULL REFERENCES entrys(id), PRIMARY KEY(session_id, entry_id));"
        }
      ]
    },
    {
      "name": "test_sessions",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"test_sessions\" (\"session_id\" TEXT NOT NULL REFERENCES sessions(id), \"wrong_answer_counter\" INTEGER NOT NULL DEFAULT 0 CHECK (wrong_answer_counter >= 0 AND wrong_answer_counter <= 4294967295), \"last_answer\" TEXT NULL CHECK (LENGTH(TRIM(last_answer)) >= 1), PRIMARY KEY(session_id));"
        }
      ]
    },
    {
      "name": "wrong_answers",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"wrong_answers\" (\"id\" TEXT NOT NULL, \"session_id\" TEXT NOT NULL REFERENCES sessions(id), \"entry_id\" TEXT NOT NULL REFERENCES entrys(id), \"value\" TEXT NOT NULL CHECK (LENGTH(TRIM(value)) >= 1), \"creation_at\" TEXT NOT NULL, PRIMARY KEY(id));"
        }
      ]
    }
